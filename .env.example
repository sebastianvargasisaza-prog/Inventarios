# Copiar este archivo a .env.local y completar los valores
# NUNCA commitear .env.local a Git

SECRET_KEY=genera-una-clave-segura-con-openssl-rand-hex-32

# Base de datos
DB_PATH=/var/data/inventario.db

# GoHighLevel CRM
GHL_API_KEY=
GHL_LOCATION_ID=

# Shopify
SHOPIFY_TOKEN=
SHOPIFY_SHOP=tu-tienda.myshopify.com

# Meta / Instagram
INSTAGRAM_TOKEN=
INSTAGRAM_USER_ID=
META_APP_ID=
META_APP_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Email SMTP
EMAIL_REMITENTE=
EMAIL_PASSWORD=

# Performance (ajustar según RAM disponible)
# 1GB RAM → 3 workers | 512MB → 1 worker | 2GB → 5 workers
WEB_CONCURRENCY=3
