# ============================================================================
# CONFIGURACIÓN DEL SISTEMA - COPIA ESTO A .env Y RELLENA CON TUS DATOS
# ============================================================================

# ANTHROPIC API (Claude)
ANTHROPIC_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GOOGLE CALENDAR (Opcional)
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_JSON=credentials.json

# NOTIFICACIONES POR EMAIL (Opcional)
# Para Gmail: generar "Contraseña de Aplicación" en https://myaccount.google.com/apppasswords
EMAIL_REMITENTE=tu_email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# BASE DE DATOS
DATABASE_URL=sqlite:///inventario.db

# DESARROLLO
DEBUG=False
PORT=5000
HOST=0.0.0.0

# ============================================================================
# INSTRUCCIONES
# ============================================================================
#
# 1. ANTHROPIC API KEY:
#    - Ve a https://console.anthropic.com/
#    - Copia tu API key
#    - Reemplaza el valor de ANTHROPIC_API_KEY
#
# 2. GOOGLE CALENDAR (Opcional):
#    - Ve a https://console.cloud.google.com/
#    - Crea un proyecto nuevo
#    - Habilita Google Calendar API
#    - Descarga las credenciales como JSON
#    - Guarda como credentials.json en la carpeta del proyecto
#    - Obtén el calendar ID desde Google Calendar settings
#
# 3. EMAIL (Opcional):
#    - Para Gmail: Habilita 2FA en tu cuenta
#    - Ve a https://myaccount.google.com/apppasswords
#    - Genera una contraseña de aplicación para "Correo"
#    - Copia la contraseña (incluye espacios)
#    - Usa como EMAIL_PASSWORD
#
# 4. GUARDAR:
#    - Renombra este archivo a .env
#    - NO subas .env a git (ya está en .gitignore)
#
# ============================================================================
